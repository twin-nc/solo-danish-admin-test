        <!-- ==================== USERS TABLE ==================== -->
        <mxCell id="tbl-users-header" value="users" style="text;html=1;strokeColor=#004B87;fillColor=#004B87;align=center;verticalAlign=middle;fontStyle=1;fontSize=13;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tbl-users-body" value="🔑 id: UUID (PK)&#xa;email: VARCHAR(255) UNIQUE NOT NULL&#xa;hashed_password: VARCHAR(255) NOT NULL&#xa;role: VARCHAR(50) NOT NULL&#xa;   (admin | officer | taxpayer)&#xa;is_active: BOOLEAN DEFAULT TRUE&#xa;created_at: TIMESTAMPTZ NOT NULL&#xa;updated_at: TIMESTAMPTZ NOT NULL" style="text;html=1;strokeColor=#004B87;fillColor=#dae8fc;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="280" height="170" as="geometry" />
        </mxCell>

        <!-- ==================== PARTIES TABLE ==================== -->
        <mxCell id="tbl-parties-header" value="parties" style="text;html=1;strokeColor=#82b366;fillColor=#82b366;align=center;verticalAlign=middle;fontStyle=1;fontSize=13;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tbl-parties-body" value="🔑 id: UUID (PK)&#xa;party_type: VARCHAR(50) NOT NULL&#xa;   (LEGAL_ENTITY | NATURAL_PERSON | etc.)&#xa;status: VARCHAR(50) NOT NULL&#xa;cvr_nummer: VARCHAR(8) [NEW — 8-digit mod-11]&#xa;se_nummer: VARCHAR(8) [NEW — tax account ID]&#xa;vat_registration_date: DATE [NEW]&#xa;afregningsperiode_type: VARCHAR(20) [NEW]&#xa;   (MONTHLY | QUARTERLY | SEMI_ANNUAL)&#xa;created_at: TIMESTAMPTZ NOT NULL&#xa;updated_at: TIMESTAMPTZ NOT NULL" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="120" width="340" height="250" as="geometry" />
        </mxCell>

        <!-- ==================== NATURAL_PERSONS TABLE ==================== -->
        <mxCell id="tbl-np-header" value="natural_persons" style="text;html=1;strokeColor=#82b366;fillColor=#82b366;align=center;verticalAlign=middle;fontStyle=1;fontSize=13;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tbl-np-body" value="🔑 id: UUID (PK, FK → parties.id)&#xa;first_name: VARCHAR(255) NOT NULL&#xa;last_name: VARCHAR(255) NOT NULL&#xa;cpr_number: VARCHAR(10)&#xa;date_of_birth: DATE&#xa;created_at: TIMESTAMPTZ&#xa;updated_at: TIMESTAMPTZ" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
