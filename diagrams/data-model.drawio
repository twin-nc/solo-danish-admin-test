        <!-- ==================== FILINGS TABLE ==================== -->
        <mxCell id="tbl-filings-header" value="filings  [CORRECTED — Danish VAT Rubrik fields]" style="text;html=1;strokeColor=#b85450;fillColor=#b85450;align=center;verticalAlign=middle;fontStyle=1;fontSize=13;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="560" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tbl-filings-body" value="🔑 id: UUID (PK)&#xa;🔗 party_id: UUID (FK → parties.id CASCADE)&#xa;se_nummer: VARCHAR(8) NOT NULL (INDEX)&#xa;afregningsperiode_type: VARCHAR(20) NOT NULL  (MONTHLY | QUARTERLY | SEMI_ANNUAL)&#xa;filing_period: VARCHAR(20) NOT NULL  (e.g. '2025-Q1', '2025-01')&#xa;frist: DATE  (legal filing deadline per Momsloven)&#xa;angivelse_type: VARCHAR(50) NOT NULL  (MOMS | SELSKABSSKAT | ...)&#xa;status: VARCHAR(50) NOT NULL DEFAULT 'KLADDE'&#xa;   (KLADDE | INDSENDT | UNDER_BEHANDLING | GODKENDT | AFVIST)&#xa;rubrik_a: NUMERIC(18,2) DEFAULT 0  — Salgsmoms (output VAT 25%)&#xa;rubrik_b: NUMERIC(18,2) DEFAULT 0  — Købsmoms (input VAT, deductible)&#xa;rubrik_c: NUMERIC(18,2) DEFAULT 0  — EU-varekøb (intra-EU acquisition VAT)&#xa;rubrik_d: NUMERIC(18,2) DEFAULT 0  — EU-varesalg (intra-EU supply, exempt)&#xa;rubrik_e: NUMERIC(18,2) DEFAULT 0  — Importmoms (import VAT)&#xa;momspligtig_omsaetning: NUMERIC(18,2) DEFAULT 0&#xa;momsfri_omsaetning: NUMERIC(18,2) DEFAULT 0&#xa;eksport: NUMERIC(18,2) DEFAULT 0&#xa;momstilsvar: NUMERIC(18,2) DEFAULT 0  — = A + C + E - B (computed)&#xa;submitted_at: TIMESTAMPTZ&#xa;kvitteringsnummer: VARCHAR(50) UNIQUE  (receipt number from SKAT)&#xa;korrektionsangivelse: BOOLEAN DEFAULT FALSE&#xa;🔗 original_filing_id: UUID (FK → filings.id SET NULL)  — for amendments&#xa;UNIQUE(se_nummer, filing_period, angivelse_type)&#xa;created_at: TIMESTAMPTZ NOT NULL&#xa;updated_at: TIMESTAMPTZ NOT NULL" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="660" width="560" height="520" as="geometry" />
        </mxCell>

        <!-- ==================== TAX_ASSESSMENTS TABLE ==================== -->
        <mxCell id="tbl-assess-header" value="tax_assessments" style="text;html=1;strokeColor=#d6b656;fillColor=#d6b656;align=center;verticalAlign=middle;fontStyle=1;fontSize=13;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="700" y="400" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tbl-assess-body" value="🔑 id: UUID (PK)&#xa;🔗 filing_id: UUID (FK → filings.id CASCADE)&#xa;🔗 party_id: UUID (FK → parties.id CASCADE)&#xa;se_nummer: VARCHAR(8) NOT NULL&#xa;assessment_date: DATE NOT NULL  [was String — now Date]&#xa;status: VARCHAR(50) NOT NULL&#xa;   (OPRETTET | UNDER_BEHANDLING | AFGJORT | AFSLUTTET)&#xa;assessed_amount: NUMERIC(18,2) NOT NULL&#xa;begrundelse: TEXT  (officer's written justification)&#xa;agterskrivelse_sent_at: TIMESTAMPTZ [NEW]&#xa;klage_frist: DATE  [NEW — appeal deadline, 3 months]&#xa;assigned_officer_id: UUID (FK → users.id)&#xa;created_at: TIMESTAMPTZ NOT NULL&#xa;updated_at: TIMESTAMPTZ NOT NULL" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="440" width="340" height="340" as="geometry" />
        </mxCell>

