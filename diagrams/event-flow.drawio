        <!-- ==================== RULE BOX ==================== -->
        <mxCell id="rule-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="580" y="640" width="400" height="240" as="geometry" />
        </mxCell>
        <mxCell id="rule-title" value="Architectural Rules" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontStyle=1;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="595" y="650" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule1" value="1. Modules NEVER call each other's services directly" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="595" y="678" width="370" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule2" value="2. Cross-module communication uses EventBus only" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="595" y="700" width="370" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule3" value="3. Events are fire-and-forget (async, no return value)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#2d6a2d;" vertex="1" parent="1">
          <mxGeometry x="595" y="722" width="370" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule4" value="4. EventBus is injected via FastAPI DI (swappable)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#2d6a2d;" vertex="1" parent="1">
          <mxGeometry x="595" y="744" width="370" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule5" value="5. InMemoryEventBus for dev/test; RabbitMQ for prod" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#004B87;" vertex="1" parent="1">
          <mxGeometry x="595" y="766" width="370" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule6" value="6. Each event includes domain context (IDs, timestamps)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#004B87;" vertex="1" parent="1">
          <mxGeometry x="595" y="788" width="370" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule7" value="7. Handlers are idempotent (safe to replay)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#6e3d9a;" vertex="1" parent="1">
          <mxGeometry x="595" y="810" width="370" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule8" value="8. No circular event dependencies between modules" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#6e3d9a;" vertex="1" parent="1">
          <mxGeometry x="595" y="832" width="370" height="20" as="geometry" />
        </mxCell>

