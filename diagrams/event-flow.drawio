        </mxCell>

        <mxCell id="handler2" value="on_assessment_completed&#xa;→ Update filing status to ASSESSED&#xa;→ Notify party (future: email)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673a6;strokeColor=#6e3d9a;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1200" y="725" width="340" height="70" as="geometry" />
        </mxCell>

        <mxCell id="handler3" value="on_party_registered&#xa;→ Log audit trail&#xa;→ Set up default filing schedule" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673a6;strokeColor=#6e3d9a;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
