        <mxCell id="handler1" value="on_filing_submitted&#xa;→ Trigger assessment creation check&#xa;→ Auto-assign officer if needed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673a6;strokeColor=#6e3d9a;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
