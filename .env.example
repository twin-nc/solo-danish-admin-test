# Copy this file to .env and fill in real values.
# The .env file is gitignored — never commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Host is 'db' when running via docker-compose; 'localhost' for local dev.
DATABASE_URL=postgresql://vatri_user:vatri_pass@db:5432/vatri_db

# PostgreSQL service credentials (used by the db container in docker-compose)
POSTGRES_USER=vatri_user
POSTGRES_PASSWORD=vatri_pass
POSTGRES_DB=vatri_db

# ── Auth (Module 2) ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_32_BYTE_HEX
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Environment ───────────────────────────────────────────────────────────────
# One of: development | staging | production
ENVIRONMENT=development